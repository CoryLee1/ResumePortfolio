# =============================================================================
# Resume Portfolio — 环境变量模板
# 使用：复制为 .env 并填写（勿 commit 真实 .env）
#   cp .env.example .env
#   cp api/.env.example api/.env
# =============================================================================

# --- 前端 (Vite) ---
# 本地开发留空：/api 由 vite 代理到 http://localhost:3001
VITE_API_URL=

# --- 本地 API（也可写在 api/.env，二选一）---
PORT=3001
CORS_ORIGIN=http://localhost:5173,https://coryresumego.vercel.app

# LLM 选择：ollama | ark | openai | auto（默认 auto）
LLM_PROVIDER=ollama

# Ollama（本地）— ollama pull qwen2.5-coder:1.5b && ollama serve
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b

# 豆包 / 火山方舟 — https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
# 生产 / Vercel 只配 ARK_* 即可（不要配 OLLAMA）
ARK_API_KEY=
ARK_MODEL=doubao-seed-2-0-pro-260215

# OpenAI（备选，未配 Ark 时使用）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# 浏览量（可选，Upstash Redis — 生产建议配置）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
